<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- ───────────────────────────────── -->
    <!--  지도 (전체화면)                   -->
    <!-- ───────────────────────────────── -->
    <com.kakao.vectormap.MapView
        android:id="@+id/mapView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- ───────────────────────────────── -->
    <!--  상단 타이틀 카드                  -->
    <!-- ───────────────────────────────── -->
    <androidx.cardview.widget.CardView
        android:id="@+id/cardTopBar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:layout_marginTop="45dp"
        app:cardCornerRadius="16dp"
        app:cardElevation="8dp"
        app:cardBackgroundColor="#FFFDF8"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- 왼쪽 오렌지 포인트 바 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <View
                android:layout_width="4dp"
                android:layout_height="match_parent"
                android:background="#E8821A" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:paddingTop="12dp"
                android:paddingBottom="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="점포 위치 등록"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="#2C1810"
                    android:letterSpacing="0.02" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text="지도를 움직여 점포 위치를 설정하세요"
                    android:textSize="12sp"
                    android:textColor="#9E8070" />
            </LinearLayout>
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- ───────────────────────────────── -->
    <!--  중앙 핀 (지도 중심 고정)          -->
    <!-- ───────────────────────────────── -->
    <LinearLayout
        android:id="@+id/layoutCenterPin"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/cardBottomSheet"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- 핀 원형 배경 -->
        <FrameLayout
            android:layout_width="48dp"
            android:layout_height="48dp">

            <!-- 핀 배경 원 (그림자 효과) -->
            <View
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="@drawable/bg_map_pin_cirecle" />

            <!-- 핀 아이콘 -->
            <ImageView
                android:id="@+id/ivPin"
                android:layout_width="26dp"
                android:layout_height="26dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_map_my_localtion"
                app:tint="#FFFFFF" />
        </FrameLayout>

        <!-- 핀 꼬리 삼각형 -->
        <View
            android:layout_width="3dp"
            android:layout_height="10dp"
            android:background="#E8821A" />

        <!-- 핀 그림자 타원 -->
        <View
            android:layout_width="14dp"
            android:layout_height="5dp"
            android:background="@drawable/bg_map_pin_shadow" />
    </LinearLayout>

    <!-- ───────────────────────────────── -->
    <!--  현재 위치 FAB                    -->
    <!-- ───────────────────────────────── -->
    <androidx.cardview.widget.CardView
        android:id="@+id/fabCurrentLocation"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="12dp"
        app:cardCornerRadius="24dp"
        app:cardElevation="6dp"
        app:cardBackgroundColor="#FFFDF8"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toTopOf="@id/cardBottomSheet">

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <ImageView
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_map_my_localtion"
                app:tint="#E8821A" />
        </FrameLayout>
    </androidx.cardview.widget.CardView>

    <!-- ───────────────────────────────── -->
    <!--  하단 등록 카드                   -->
    <!-- ───────────────────────────────── -->
    <androidx.cardview.widget.CardView
        android:id="@+id/cardBottomSheet"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:layout_marginEnd="12dp"
        android:layout_marginBottom="25dp"
        app:cardCornerRadius="20dp"
        app:cardElevation="12dp"
        app:cardBackgroundColor="#FFFDF8"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:paddingTop="20dp"
            android:paddingBottom="20dp">

            <!-- 주소 행 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/bg_map_address_box"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:paddingTop="12dp"
                android:paddingBottom="12dp">

                <!-- 위치 아이콘 배경 원 -->
                <FrameLayout
                    android:layout_width="32dp"
                    android:layout_height="32dp">

                    <View
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:background="@drawable/bg_map_icon_circle_orange" />

                    <ImageView
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_map_my_localtion"
                        app:tint="#FFFFFF" />
                </FrameLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginStart="12dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="선택된 위치"
                        android:textSize="10sp"
                        android:textColor="#B09080"
                        android:letterSpacing="0.05" />

                    <TextView
                        android:id="@+id/tvSelectedAddress"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:text="지도를 움직여 위치를 선택하세요"
                        android:textSize="13sp"
                        android:textColor="#2C1810"
                        android:maxLines="2"
                        android:ellipsize="end"
                        android:lineSpacingMultiplier="1.3" />
                </LinearLayout>
            </LinearLayout>

            <!-- 버튼 행 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="14dp">

                <!-- 현재 위치 버튼 (아웃라인) -->
                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/btnCurrentLocation"
                    android:layout_width="0dp"
                    android:layout_height="50dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="8dp"
                    android:text="현재 위치"
                    android:textSize="13sp"
                    android:textColor="#E8821A"
                    android:textStyle="bold"
                    android:background="@drawable/bg_map_btn_outline_orange"
                    android:stateListAnimator="@null" />

                <!-- 등록 버튼 (채움) -->
                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/btnRegisterLocation"
                    android:layout_width="0dp"
                    android:layout_height="50dp"
                    android:layout_weight="1.6"
                    android:text="이 위치로 등록"
                    android:textSize="14sp"
                    android:textColor="#FFFFFF"
                    android:textStyle="bold"
                    android:letterSpacing="0.02"
                    android:background="@drawable/bg_map_btn_filled_orange"
                    android:stateListAnimator="@null" />
            </LinearLayout>
        </LinearLayout>
    </androidx.cardview.widget.CardView>

</androidx.constraintlayout.widget.ConstraintLayout>