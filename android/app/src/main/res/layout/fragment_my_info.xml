<?xml version="1.0" encoding="utf-8"?>
<!--
    fragment_my_info.xml
    카카오 로그인 전용 - 프로필은 카카오에서 받아온 정보만 표시
    홈 색상 동일: 주황(#E8821A) 헤더, 베이지(#F5EFE0) 배경, 흰 카드 + #F0D9B5 테두리
-->
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5EFE0"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- ══════════════════════════════
             카카오 프로필 헤더 (주황 배경)
        ══════════════════════════════ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#E8821A"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="45dp"
            android:paddingBottom="18dp">

            <!-- 화면 타이틀 -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="나의 정보"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:layout_marginBottom="14dp" />

            <!-- 프로필 행 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <!-- 카카오 프로필 이미지 -->
                <com.google.android.material.imageview.ShapeableImageView
                    android:id="@+id/ivKakaoProfile"
                    android:layout_width="58dp"
                    android:layout_height="58dp"
                    android:scaleType="centerCrop"
                    android:background="#FEE500"
                    app:shapeAppearance="@style/CircleShape"
                    app:strokeColor="#80FFFFFF"
                    app:strokeWidth="2dp" />

                <!-- 이름 + 카카오 뱃지 -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:paddingStart="15dp">

                    <TextView
                        android:id="@+id/tvUserName"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="사용자 이름"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:textColor="#FFFFFF" />

                    <TextView
                        android:id="@+id/tvKakaoEmail"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:text="카카오 계정 연동"
                        android:textSize="12sp"
                        android:textColor="#FFD4A8" />

                    <!-- 카카오 로그인 뱃지 -->
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:background="@drawable/bg_my_info_icon_kakao_badge"
                        android:paddingStart="8dp"
                        android:paddingEnd="10dp"
                        android:paddingTop="3dp"
                        android:paddingBottom="3dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="💛"
                            android:textSize="12sp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="4dp"
                            android:text="카카오 로그인"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            android:textColor="#3A1D1D" />

                    </LinearLayout>

                </LinearLayout>

            </LinearLayout>

        </LinearLayout>

        <!-- ══════════════════════════════
             활동 통계 (3개 카드)
        ══════════════════════════════ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingStart="10dp"
            android:paddingEnd="10dp"
            android:paddingTop="18dp"
            android:paddingBottom="6dp">

            <!-- 총 판매 -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="4dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="0dp"
                app:strokeColor="#F0D9B5"
                app:strokeWidth="1.5dp"
                app:cardBackgroundColor="#FFFFFF">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:padding="15dp">

                    <TextView
                        android:id="@+id/tvSaleCount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textSize="25sp"
                        android:textStyle="bold"
                        android:textColor="#E8821A" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="총 판매"
                        android:textSize="14sp"
                        android:textColor="#BBBBA8"
                        android:layout_marginTop="2dp" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- 등록중 -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="4dp"
                android:layout_marginEnd="4dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="0dp"
                app:strokeColor="#F0D9B5"
                app:strokeWidth="1.5dp"
                app:cardBackgroundColor="#FFFFFF">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:padding="15dp">

                    <TextView
                        android:id="@+id/tvActiveCount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textSize="25sp"
                        android:textStyle="bold"
                        android:textColor="#E8821A" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="등록중"
                        android:textSize="14sp"
                        android:textColor="#BBBBA8"
                        android:layout_marginTop="2dp" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- 조회수 -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="4dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="0dp"
                app:strokeColor="#F0D9B5"
                app:strokeWidth="1.5dp"
                app:cardBackgroundColor="#FFFFFF">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:padding="15dp">

                    <TextView
                        android:id="@+id/tvViewCount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textSize="25sp"
                        android:textStyle="bold"
                        android:textColor="#E8821A" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="조회수"
                        android:textSize="14sp"
                        android:textColor="#BBBBA8"
                        android:layout_marginTop="2dp" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>

        <!-- ══════════════════════════════
             내 판매 섹션
        ══════════════════════════════ -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="내 판매"
            android:textSize="15sp"
            android:textStyle="bold"
            android:textColor="#A8A89A"
            android:paddingStart="14dp"
            android:paddingTop="16dp"
            android:paddingBottom="8dp" />

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="10dp"
            android:layout_marginEnd="10dp"
            app:cardCornerRadius="14dp"
            app:cardElevation="0dp"
            app:strokeColor="#F0D9B5"
            app:strokeWidth="1.5dp"
            app:cardBackgroundColor="#FFFFFF">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <!-- 판매 목록 -->
                <LinearLayout
                    android:id="@+id/menuSalesList"
                    android:layout_width="match_parent"
                    android:layout_height="55dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingStart="13dp"
                    android:paddingEnd="13dp"
                    android:background="?attr/selectableItemBackground">

                    <TextView
                        android:layout_width="30dp"
                        android:layout_height="30dp"
                        android:gravity="center"
                        android:text="📋"
                        android:textSize="15sp"
                        android:background="@drawable/bg_menu_icon_orange" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="10dp"
                        android:text="판매 목록"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textColor="#1A1A1A" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="›"
                        android:textSize="18sp"
                        android:textColor="#D4C9B0" />

                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginStart="53dp"
                    android:background="#FAF4E8" />

                <!-- 재고 관리 -->
                <LinearLayout
                    android:id="@+id/menuStockManage"
                    android:layout_width="match_parent"
                    android:layout_height="55dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingStart="13dp"
                    android:paddingEnd="13dp"
                    android:background="?attr/selectableItemBackground">

                    <TextView
                        android:layout_width="30dp"
                        android:layout_height="30dp"
                        android:gravity="center"
                        android:text="📦"
                        android:textSize="15sp"
                        android:background="@drawable/bg_menu_icon_yellow" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="10dp"
                        android:text="재고 관리"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textColor="#1A1A1A" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="›"
                        android:textSize="18sp"
                        android:textColor="#D4C9B0" />

                </LinearLayout>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ══════════════════════════════
             활동 섹션
        ══════════════════════════════ -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="활동"
            android:textSize="15sp"
            android:textStyle="bold"
            android:textColor="#A8A89A"
            android:paddingStart="14dp"
            android:paddingTop="16dp"
            android:paddingBottom="8dp" />

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="10dp"
            android:layout_marginEnd="10dp"
            app:cardCornerRadius="14dp"
            app:cardElevation="0dp"
            app:strokeColor="#F0D9B5"
            app:strokeWidth="1.5dp"
            app:cardBackgroundColor="#FFFFFF">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <!-- 채팅 목록 -->
                <LinearLayout
                    android:id="@+id/menuChatList"
                    android:layout_width="match_parent"
                    android:layout_height="55dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingStart="13dp"
                    android:paddingEnd="13dp"
                    android:background="?attr/selectableItemBackground">

                    <TextView
                        android:layout_width="30dp"
                        android:layout_height="30dp"
                        android:gravity="center"
                        android:text="💬"
                        android:textSize="15sp"
                        android:background="@drawable/bg_info_menu_icon_blue" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="10dp"
                        android:text="채팅 목록"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textColor="#1A1A1A" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="›"
                        android:textSize="18sp"
                        android:textColor="#D4C9B0" />

                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginStart="53dp"
                    android:background="#FAF4E8" />

                <!-- 관심 받은 상품 -->
                <LinearLayout
                    android:id="@+id/menuLikedProducts"
                    android:layout_width="match_parent"
                    android:layout_height="55dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingStart="13dp"
                    android:paddingEnd="13dp"
                    android:background="?attr/selectableItemBackground">

                    <TextView
                        android:layout_width="30dp"
                        android:layout_height="30dp"
                        android:gravity="center"
                        android:text="♡"
                        android:textSize="15sp"
                        android:background="@drawable/bg_menu_icon_orange" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="10dp"
                        android:text="관심 받은 상품"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textColor="#1A1A1A" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="›"
                        android:textSize="18sp"
                        android:textColor="#D4C9B0" />

                </LinearLayout>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ══════════════════════════════
             계정 섹션
        ══════════════════════════════ -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="계정"
            android:textSize="15sp"
            android:textStyle="bold"
            android:textColor="#A8A89A"
            android:paddingStart="14dp"
            android:paddingTop="16dp"
            android:paddingBottom="8dp" />

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="10dp"
            android:layout_marginEnd="10dp"
            android:layout_marginBottom="24dp"
            app:cardCornerRadius="14dp"
            app:cardElevation="0dp"
            app:strokeColor="#F0D9B5"
            app:strokeWidth="1.5dp"
            app:cardBackgroundColor="#FFFFFF">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <!-- 설정 -->
                <LinearLayout
                    android:id="@+id/menuSettings"
                    android:layout_width="match_parent"
                    android:layout_height="55dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingStart="13dp"
                    android:paddingEnd="13dp"
                    android:background="?attr/selectableItemBackground">

                    <TextView
                        android:layout_width="30dp"
                        android:layout_height="30dp"
                        android:gravity="center"
                        android:text="⚙"
                        android:textSize="15sp"
                        android:background="@drawable/bg_info_menu_icon_blue" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="10dp"
                        android:text="설정"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textColor="#1A1A1A" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="›"
                        android:textSize="18sp"
                        android:textColor="#D4C9B0" />

                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginStart="53dp"
                    android:background="#FAF4E8" />

                <!-- 로그아웃 (카카오) -->
                <LinearLayout
                    android:id="@+id/menuLogout"
                    android:layout_width="match_parent"
                    android:layout_height="55dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingStart="13dp"
                    android:paddingEnd="13dp"
                    android:background="?attr/selectableItemBackground">

                    <TextView
                        android:layout_width="30dp"
                        android:layout_height="30dp"
                        android:gravity="center"
                        android:text="🚪"
                        android:textSize="15sp"
                        android:background="@drawable/bg_info_menu_icon_red" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="10dp"
                        android:text="로그아웃"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textColor="#C62828" />

                </LinearLayout>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>
</androidx.core.widget.NestedScrollView>