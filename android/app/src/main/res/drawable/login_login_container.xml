<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <layer-list>
            <item android:top="4dp">
                <shape>
                    <solid android:color="@color/orange_dark" />
                    <corners android:radius="16dp" />
                </shape>
            </item>
            <item android:bottom="2dp">
                <shape>
                    <gradient
                        android:angle="135"
                        android:endColor="@color/orange_dark"
                        android:startColor="@color/orange_main"
                        android:type="linear" />
                    <corners android:radius="16dp" />
                </shape>
            </item>
        </layer-list>
    </item>
    <item>
        <layer-list>
            <item android:top="4dp">
                <shape>
                    <solid android:color="@color/orange_dark" />
                    <corners android:radius="16dp" />
                </shape>
            </item>
            <item android:bottom="4dp">
                <shape>
                    <gradient
                        android:angle="135"
                        android:endColor="@color/orange_dark"
                        android:startColor="@color/orange_main"
                        android:type="linear" />
                    <corners android:radius="16dp" />
                </shape>
            </item>
        </layer-list>
    </item>
</selector>